# --- Context Nest MCP Host (Service 1) ---
# Copy to .env.local for local dev; set the same vars in the Vercel project.

# Storage backend selected by the engine's Storage Factory: "blob" | "fs"
# Use "blob" on Vercel, "fs" for local development against a real directory.
CONTEXTNEST_STORAGE=blob

# Local-only: path to a vault directory when CONTEXTNEST_STORAGE=fs
# CONTEXTNEST_VAULT_PATH=./.vault

# Vercel Blob (BlobStorageProvider). Provided automatically when a Blob store
# is linked to the Vercel project; set manually for local dev.
BLOB_READ_WRITE_TOKEN=

# GitHub repo that holds vault version history (source of truth).
CONTEXTNEST_VAULT_REPO=jhs129/contextnest-vault

# GitHub OAuth App (Service 1 web session + MCP auth). repo scope required.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth / OAuth 2.1 signing
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
