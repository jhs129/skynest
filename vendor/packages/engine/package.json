  },
  "keywords": [
    "ai",
    "llm",
    "context",
    "knowledge-base",
    "versioning",
    "hash-chain",
    "integrity",
    "selector",
    "graph-traversal",
    "markdown",
    "ai-agents",
    "context-management"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
