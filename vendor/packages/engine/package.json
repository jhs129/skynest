    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/toposort": "^2.0.7",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
